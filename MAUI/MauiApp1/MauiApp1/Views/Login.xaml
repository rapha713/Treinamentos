<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Login"
             Title="Login">

    <Grid RowDefinitions="Auto,*,Auto" Padding="30">

        <VerticalStackLayout Grid.Row="0" Spacing="10">

            <Label 
                Text="Bem Vindo"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="#ac99ea"/>

        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="20">

            <Frame 
                CornerRadius="12"
                BackgroundColor="White"
                Padding="10"
                HasShadow="True">

                <Entry
                    Text="{Binding User}"
                    Placeholder="Usuário"
                    BackgroundColor="Transparent"
                    TextColor="Black"/>
            </Frame>

            <Frame
                CornerRadius="12"
                BackgroundColor="White"
                Padding="10"    
                HasShadow="True">

                <Grid ColumnDefinitions="*,Auto">

                    <Entry 
                        Text="{Binding Password}"
                        Placeholder="Senha"
                        IsPassword="True"
                        BackgroundColor="Transparent"
                        Grid.Column="0"
                        TextColor="Black"/>

                    <ImageButton 
                        x:Name="TogglePasswordButton"
                        Source="eye.png"
                        WidthRequest="24"
                        HeightRequest="24"
                        BackgroundColor="Transparent"
                        VerticalOptions="Center"
                        Grid.Column="1"
                        Clicked="OnTogglePasswordClicked"/>

                    <!--SEGURAR PARA APARECER usando svg-->
                    <!--<Grid.GestureRecognizers>
                            <PointerGestureRecognizer 
                                PointerEntered="OnHoverEnter"
                                PointerExited="OnHoverExit"
                                PointerPressed="OnPressed"
                                PointerReleased="OnReleased"/>
                        </Grid.GestureRecognizers>-->
                </Grid>
            </Frame>

            <Button 
                x:Name="LoginButton"
                Text="Entrar"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="12"
                HeightRequest="50"
                Command="{Binding LoginCommand}"/>

            <ActivityIndicator
                x:Name="LoadingIndicator"
                IsRunning="False"
                IsVisible="False"
                Color="#512BD4"/>

        </VerticalStackLayout>

        <Label 
            Text="Esqueci minha senha"
            FontSize="12"
            HorizontalOptions="Center"
            Grid.Row="2" />
    </Grid>
    
</ContentPage>